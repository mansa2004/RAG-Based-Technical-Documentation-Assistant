
# LLM provider: groq | google | openai | anthropic
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0

# API key for whichever provider you picked above (uncomment the one you need)
GROQ_API_KEY=your_groq_key_here
# GOOGLE_API_KEY=your_google_key_here
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Embeddings: local (no key needed) | openai
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector store
COLLECTION_NAME=tech_docs

# Chunking
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# Retrieval 
TOP_K=4

# Self-correction
MAX_RETRIES=2
ENABLE_HALLUCINATION_CHECK=true
ENABLE_WEB_SEARCH_FALLBACK=false

# Requires a free key from tavily.com.
TAVILY_API_KEY=your_tavily_key_here


